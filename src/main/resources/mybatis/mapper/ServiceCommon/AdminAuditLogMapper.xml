<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<!-- 命名空间：对应Mapper接口全类名 -->
<mapper namespace="org.myfx.controls.aione.ServiceCommon.mapper.AdminAuditLogMapper">

    <!-- 结果映射：实体类 ↔ 数据库表 -->
    <resultMap id="AdminAuditLogResultMap" type="org.myfx.controls.aione.ServiceCommon.entity.AdminAuditLog">
        <id column="id" property="id"/>
        <result column="user_id" property="userId"/>
        <result column="method_name" property="methodName"/>
        <result column="request_params" property="requestParams"/>
        <result column="response_params" property="responseParams"/>
        <result column="operate_status" property="operateStatus"/>
        <result column="error_msg" property="errorMsg"/>
        <result column="create_time" property="createTime"/>
    </resultMap>

    <!-- 1. 新增审计日志（数据库自动生成时间，无需插入create_time） -->
    <insert id="insert">
        INSERT INTO admin_audit_log (
            user_id, method_name, request_params, response_params, operate_status, error_msg
        ) VALUES (
                     #{userId}, #{methodName}, #{requestParams}, #{responseParams}, #{operateStatus}, #{errorMsg}
                 )
    </insert>

    <!-- 2. 查询全部日志（使用*，极简） -->
    <select id="selectAll" resultMap="AdminAuditLogResultMap">
        SELECT * FROM admin_audit_log
    </select>

    <!-- 3. 根据userId查询日志（使用*） -->
    <select id="selectByUserId" resultMap="AdminAuditLogResultMap">
        SELECT * FROM admin_audit_log WHERE user_id = #{userId}
    </select>

</mapper>