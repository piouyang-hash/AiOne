<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="org.myfx.controls.aione.AiService.mapper.user_behavior_db.UserFeatureScoreMapper">

    <!-- 基础ResultMap：移除session_id字段映射，保留核心业务字段 -->
    <resultMap id="UserFeatureScoreResultMap" type="org.myfx.controls.aione.AiService.entity.user_behavior_db.UserFeatureScore">
        <id column="id" property="id"/>
        <result column="user_id" property="userId"/>
        <result column="activity_score" property="activityScore"/>
        <result column="favor_score" property="favorScore"/>
        <result column="familiar_score" property="familiarScore"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <!-- 1. 新增（C）：核心业务字段，时间由数据库自动填充（移除session_id） -->
    <insert id="insert" parameterType="org.myfx.controls.aione.AiService.entity.user_behavior_db.UserFeatureScore">
        INSERT INTO user_feature_score (id, user_id, activity_score, favor_score, familiar_score)
        VALUES (#{id}, #{userId}, #{activityScore}, #{favorScore}, #{familiarScore})
    </insert>

    <!-- 2. 查询（R）：根据user_id查询唯一记录（纯用户维度） -->
    <select id="selectByUserId" resultMap="UserFeatureScoreResultMap">
        SELECT * FROM user_feature_score
        WHERE user_id = #{userId}
    </select>

    <!-- 查询所有活跃度为0的用户ID -->
    <select id="selectUserIdsByActivityScoreZero" resultType="java.lang.Integer">
        SELECT user_id
        FROM user_feature_score
        WHERE activity_score = 0
        <!-- 可选：按更新时间排序，优先处理最近变0的用户 -->
        ORDER BY update_time DESC
    </select>

    <!-- 3. 更新（U）：根据user_id更新分值，自动更新时间（移除session_id） -->
    <update id="updateByUserId" parameterType="org.myfx.controls.aione.AiService.entity.user_behavior_db.UserFeatureScore">
        UPDATE user_feature_score
        <trim prefix="SET" suffixOverrides=",">
            <if test="activityScore != null">activity_score = #{activityScore},</if>
            <if test="favorScore != null">favor_score = #{favorScore},</if>
            <if test="familiarScore != null">familiar_score = #{familiarScore},</if>
            update_time = NOW()
        </trim>
        WHERE user_id = #{userId}
    </update>

    <!-- 4. 删除：根据user_id删除该用户记录 -->
    <delete id="deleteByUserId" parameterType="java.lang.Integer">
        DELETE FROM user_feature_score
        WHERE user_id = #{userId}
    </delete>

</mapper>