<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="org.myfx.controls.aione.SimulationGame.mapper.SimulateEventMapper">

    <!-- 定义 SimulateEvent ResultMap（补充默认耗时字段映射） -->
    <resultMap id="SimulateEventResultMap" type="org.myfx.controls.aione.SimulationGame.entity.SimulateEvent">
        <id column="event_id" property="eventId"/>
        <result column="event_code" property="eventCode"/>
        <result column="event_desc" property="eventDesc"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <!-- 新增事件（补充default_duration字段） -->
    <insert id="insert" parameterType="map">
        INSERT INTO simulate_event (event_code, event_desc)
        VALUES (#{eventCode}, #{eventDesc})
    </insert>

    <!-- 根据ID查询 -->
    <select id="selectById" parameterType="java.lang.Integer" resultMap="SimulateEventResultMap">
        SELECT * FROM simulate_event
        WHERE event_id = #{eventId}
    </select>

    <!-- 查询所有事件（无参数） -->
    <select id="selectAll" resultMap="SimulateEventResultMap">
        SELECT *
        FROM simulate_event
        ORDER BY event_id
    </select>

    <!-- 根据编码精准查询 -->
    <select id="selectByCode" parameterType="java.lang.String" resultMap="SimulateEventResultMap">
        SELECT * FROM simulate_event
        WHERE event_code = #{eventCode}
    </select>

    <!-- 根据编码精准删除 -->
    <delete id="deleteByCode" parameterType="java.lang.String">
        DELETE FROM simulate_event
        WHERE event_code = #{eventCode}
    </delete>

</mapper>